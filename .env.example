# Copy this file to .env and fill in your values
# Place this .env file in the project root (same folder as pnpm-workspace.yaml)

# MySQL connection string for XAMPP (default: no password for root)
DATABASE_URL=mysql://root:@localhost:3306/adypu_chat

# Your OpenAI API key (needed for embeddings and chat completions)
OPENAI_API_KEY=sk-...

# API server port (backend)
API_PORT=3000

# Frontend port (the browser UI)
FRONTEND_PORT=5173
